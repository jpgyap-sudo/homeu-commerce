{
  "name": "homeu-commerce-monorepo",
  "private": true,
  "description": "HomeU Commerce — Monorepo root",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:classify": "powershell -ExecutionPolicy Bypass -File C:/Users/user/.superroo/skills/minimal-docker-image-build/scripts/classify-build-impact.ps1 -Repo .",
    "build:website": "npm run build -w apps/website",
    "build:docker:builder": "docker build --target builder -t homeu-website:builder .",
    "build:docker:image": "docker build -t homeu-website:local .",
    "compose:config": "docker compose config",
    "dev": "npm run dev -w apps/website",
    "lint": "npm run lint --workspaces --if-present",
    "migrate": "node tools/migrate/migrate.mjs",
    "migrate:status": "node tools/migrate/migrate.mjs --status",
    "migrate:create": "node tools/migrate/migrate.mjs --create",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1072.0",
    "image-size": "^2.0.2"
  }
}
