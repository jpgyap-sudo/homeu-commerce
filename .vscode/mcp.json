{
  "servers": {
    "homeu-deployer": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/tools/deployer-agent/deployer-mcp.mjs"
      ],
      "description": "🚀 DEPLOYER AGENT — Central coordinator for ALL coding extensions. Prevents duplicate builds. Call deployer_deploy instead of docker compose directly.",
      "env": {
        "DEPLOYER_EXTENSION_ID": "vscode-${workspaceName}"
      }
    },
    "shopify-homeu": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/tools/shopify-mcp/server.mjs"
      ],
      "description": "🔒 READ-ONLY Shopify Admin API — lists products, collections, pages, themes, blogs",
      "env": {
        "SHOPIFY_STORE": "",
        "SHOPIFY_TOKEN": ""
      }
    },
    "shopify-hub": {
      "type": "stdio",
      "command": "node",
      "args": [
        "C:/Users/user/.superroo/mcp/shopify-hub.mjs"
      ],
      "description": "Shared SuperRoo Shopify MCP hub, read-only by default.",
      "env": {
        "SUPERROO_HOME": "C:/Users/user/.superroo",
        "SUPERROO_MCP_CLIENT_ID": "vscode-homeu",
        "SUPERROO_SHOPIFY_MODE": "read-only",
        "SHOPIFY_API_VERSION": "2025-10",
        "SHOPIFY_STORE": "",
        "SHOPIFY_ADMIN_TOKEN": ""
      }
    }
  }
}
