# ══════════════════════════════════════════════════════════
#  HomeU Commerce — Environment Configuration
# ══════════════════════════════════════════════════════════
#  🔒 DO NOT COMMIT THIS FILE OR .env TO VERSION CONTROL
# ══════════════════════════════════════════════════════════
#
# Generate a strong secret:
#   openssl rand -base64 48
#
# Production values (update before deploying):
#   DAVINCIOS_PUBLIC_SERVER_URL=https://admin.homeu.ph
#   NEXT_PUBLIC_SITE_URL=https://store.homeu.ph
#   DATABASE_URI=postgres://homeu:STRONG_PASSWORD@postgres:5432/homeu

# === Website / Next.js ===
NEXT_PUBLIC_SITE_URL=https://store.homeu.ph
NEXT_PUBLIC_SITE_NAME=HomeU

# === DaVinciOS CMS ===
# Required: Generate a strong random secret (min 32 chars)
# Example: openssl rand -base64 48
DAVINCIOS_SECRET=replace-with-openssl-rand-base64-48-output
DAVINCIOS_PUBLIC_SERVER_URL=https://admin.homeu.ph

# === Database (PostgreSQL) ===
# The database runs in a Docker container on the internal network
# Use a STRONG password in production
DATABASE_URI=postgres://homeu:STRONG_DB_PASSWORD_HERE@postgres:5432/homeu

# === HomeU Concierge Chatbot ===
# AI Provider (gemini | openai | ollama)
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Telegram alerts for sales team
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# Sales contact
SALES_VIBER_NUMBER=+639171234567
SALES_VIBER_NAME=HomeU Sales Team
SALES_EMAIL=sales@homeu.ph

# Chat widget configuration
NEXT_PUBLIC_SALES_VIBER_NUMBER=+639171234567
NEXT_PUBLIC_SALES_VIBER_NAME=HomeU Sales Team
NEXT_PUBLIC_CHAT_GREETING_DELAY=4000
NEXT_PUBLIC_CHAT_PRODUCT_PAGE_DELAY=7000
NEXT_PUBLIC_ENABLE_CHAT=true

# File storage for chat uploads (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=homeu-chat-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# === DigitalOcean Spaces (CDN media: Products, Categories, Blogs, Pages) ===
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=homeatelierspaces
DO_SPACES_ORIGIN_ENDPOINT=https://homeatelierspaces.sgp1.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=https://homeatelierspaces.sgp1.cdn.digitaloceanspaces.com
DO_SPACES_KEY=
DO_SPACES_SECRET=
