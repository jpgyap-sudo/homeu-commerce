# ⚠️ SECURITY WARNING ⚠️
# Never commit this file or the .env file to version control!
# Generate a STRONG random secret for PAYLOAD_SECRET:
#   openssl rand -base64 48
#
# For production, use MANAGED secrets or environment variables,
# never hardcode passwords in files accessible by users.

# === Website ===
NEXT_PUBLIC_SITE_URL=https://store.homeu.ph
NEXT_PUBLIC_SITE_NAME=HomeU

# === Payload CMS Security ===
# Generate with: openssl rand -base64 48 (at least 32 chars)
PAYLOAD_SECRET=change-this-to-a-random-secret-at-least-32-chars
PAYLOAD_PUBLIC_SERVER_URL=https://admin.homeu.ph

# === Database ===
# Use a STRONG password in production (not this default)
# The database is only accessible from within the Docker network
DATABASE_URI=postgres://homeu:STRONG_DB_PASSWORD_HERE@postgres:5432/homeu
