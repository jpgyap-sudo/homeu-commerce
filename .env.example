# ══════════════════════════════════════════════════════════
#  HomeU Commerce — Environment Configuration
# ══════════════════════════════════════════════════════════
#  🔒 DO NOT COMMIT THIS FILE OR .env TO VERSION CONTROL
# ══════════════════════════════════════════════════════════
#
# Generate a strong secret:
#   openssl rand -base64 48
#
# Production values (update before deploying):
#   PAYLOAD_PUBLIC_SERVER_URL=https://admin.homeu.ph
#   NEXT_PUBLIC_SITE_URL=https://store.homeu.ph
#   DATABASE_URI=postgres://homeu:STRONG_PASSWORD@postgres:5432/homeu

# === Website / Next.js ===
NEXT_PUBLIC_SITE_URL=https://store.homeu.ph
NEXT_PUBLIC_SITE_NAME=HomeU

# === Payload CMS ===
# Required: Generate a strong random secret (min 32 chars)
# Example: openssl rand -base64 48
PAYLOAD_SECRET=replace-with-openssl-rand-base64-48-output
PAYLOAD_PUBLIC_SERVER_URL=https://admin.homeu.ph
# Disable telemetry
PAYLOAD_TELEMETRY_DISABLED=true

# === Database (PostgreSQL) ===
# The database runs in a Docker container on the internal network
# Use a STRONG password in production
DATABASE_URI=postgres://homeu:STRONG_DB_PASSWORD_HERE@postgres:5432/homeu
